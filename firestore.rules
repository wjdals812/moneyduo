
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // users 컬렉션: 기본 원칙 — 문서 수정은 본인만 가능
    // 다른 사용자는 같은 커플인 경우에 한해 읽을 수 있도록 허용
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || (
          // 같은 coupleId를 가질 때 읽기 허용
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coupleId == resource.data.coupleId
          && resource.data.coupleId != null
        )
      );

      // 생성은 본인 UID로만 가능
      allow create: if isSignedIn() && request.auth.uid == userId;

      // 업데이트는 본인만 가능. 특히 `coupleId` 필드의 변경은 클라이언트에서 금지
      // (커플 가입/탈퇴는 서버(Cloud Function)으로 처리하는 것을 권장)
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && (
          // 기존 문서가 없을 때는 허용 (create 경로로 처리)
          !exists(/databases/$(database)/documents/users/$(userId))
          || (
            request.resource.data.coupleId == resource.data.coupleId
            || request.resource.data.coupleId == null
            || (
              request.resource.data.coupleId is string
              && resource.data.coupleId == null
              && exists(/databases/$(database)/documents/couples/$(request.resource.data.coupleId))
              && get(/databases/$(database)/documents/couples/$(request.resource.data.coupleId)).data.members.hasAny([request.auth.uid])
            )
          )
        );

      allow delete: if false;
    }

    // transactions: 생성은 요청한 사용자가 자신의 uid로 생성해야 하며,
    // 수정/삭제는 생성자만 할 수 있음. 같은 커플의 다른 사용자는 읽기 허용.
    match /transactions/{txId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.createdBy
        || (
          // 동일한 couple의 멤버는 읽을 수 있음
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && exists(/databases/$(database)/documents/users/$(resource.data.createdBy))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coupleId == get(/databases/$(database)/documents/users/$(resource.data.createdBy)).data.coupleId
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coupleId != null
        )
      );
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.createdBy;
    }

    // couples: 읽기는 멤버만 가능. 생성은 본인만 멤버로 한 채로 허용.
    // 클라이언트에서 스스로 초대 코드로 참여하거나 탈퇴할 수 있도록 제한적으로 허용.
    match /couples/{coupleId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;

      allow create: if isSignedIn()
        && request.resource.data.members is list
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0] == request.auth.uid
        && request.resource.data.inviteCode is string;

      allow update: if isSignedIn()
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.members is list
        && resource.data.members is list
        && (
          // 초대 코드로 가입: 본인만 새 멤버로 추가
          (!resource.data.members.hasAny([request.auth.uid])
            && request.resource.data.members.hasAny([request.auth.uid])
            && request.resource.data.members.hasAll(resource.data.members)
            && request.resource.data.members.size() == resource.data.members.size() + 1)
          ||
          // 탈퇴: 본인을 멤버에서 제거
          (resource.data.members.hasAny([request.auth.uid])
            && !request.resource.data.members.hasAny([request.auth.uid])
            && request.resource.data.members.size() == resource.data.members.size() - 1
            && resource.data.members.hasAll(request.resource.data.members))
        );

      allow delete: if isSignedIn()
        && request.auth.uid in resource.data.members
        && resource.data.members.size() == 1;
    }
  }
}

